{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "functions/**"],
    "headers": [
      { "source": "**/*.@(js|html|css)", "headers": [ { "key": "Cache-Control", "value": "no-cache" } ] }
    ]
  },
  "functions": [
    { "source": "functions", "codebase": "default" }
  ],
  "firestore": { "rules": "firestore.rules" },
  "storage": { "rules": "storage.rules" }
}
